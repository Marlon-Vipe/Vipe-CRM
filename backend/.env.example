PORT=4001

# URL pública del frontend — se usa para construir los enlaces de invitación
# y las URLs de retorno de checkout/portal de facturación.
FRONTEND_URL=http://localhost:5173

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# El email de invitaciones se envía con el servicio de correo integrado de
# Supabase Auth (auth.admin.inviteUserByEmail) — no requiere ninguna variable
# extra, usa SUPABASE_SERVICE_ROLE_KEY de arriba. Es gratis pero Supabase lo
# limita a unos pocos correos por hora por proyecto sin SMTP propio (ver
# Authentication → Settings → SMTP Settings en el dashboard si el volumen
# crece). Si el envío falla o no está configurado, la invitación se sigue
# creando igual — queda el respaldo de "Copiar enlace" en la pantalla Equipo.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# BILLING_PROVIDER selecciona la implementación detrás de src/lib/billing —
# por ahora solo existe "stripe", pero el resto del módulo (endpoints,
# tabla subscriptions) es agnóstico al proveedor. Ver src/lib/billing/index.js.
BILLING_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
